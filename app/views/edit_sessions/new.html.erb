<div class="landing-page">
  <div class="landing-card">
    <h1>Sprite Extractor</h1>
    <p>Upload an image to select and clear its background.</p>

    <button type="button" class="dropzone-button" data-action="global-actions#openFileDialog">
      <i class="bi bi-cloud-upload"></i>
      <span>Drop an image here, or click to choose a file</span>
    </button>

    <button type="button" class="load-session-button" data-action="global-actions#openLoadDialog">
      <i class="bi bi-folder2-open"></i>
      Load Session
    </button>
  </div>
</div>
